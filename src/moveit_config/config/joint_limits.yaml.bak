    max_velocity: 2.0
    has_acceleration_limits: false
    max_acceleration: 0
  joint4:
    has_position_limits: false
    has_velocity_limits: true
    max_velocity: 2.0
    has_acceleration_limits: false
    max_acceleration: 0
  joint5:
    has_position_limits: false
    has_velocity_limits: true
    max_velocity: 2.0
    has_acceleration_limits: false
    max_acceleration: 0
  joint6:
    has_position_limits: false
